<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Naqeeb Ahmed | AI & ML Portfolio</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;500;600;700;800;900&family=Rajdhani:wght@300;400;500;600;700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r158/three.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/cannon.js/0.6.2/cannon.min.js"></script>
    <style>
        *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
        
        :root {
            --electric-blue: #00d4ff;
            --deep-violet: #7c3aed;
            --cosmic-gold: #ffd700;
            --dark-void: #050510;
            --glow-blue: 0 0 20px rgba(0, 212, 255, 0.6), 0 0 40px rgba(0, 212, 255, 0.3);
            --glow-violet: 0 0 20px rgba(124, 58, 237, 0.6), 0 0 40px rgba(124, 58, 237, 0.3);
            --glow-gold: 0 0 20px rgba(255, 215, 0, 0.6), 0 0 40px rgba(255, 215, 0, 0.3);
        }
        
        body {
            background: var(--dark-void);
            color: #e0e0ff;
            font-family: 'Rajdhani', sans-serif;
            overflow-x: hidden;
            cursor: none;
            min-height: 100vh;
        }
        
        #canvas-container {
            position: fixed;
            top: 0; left: 0;
            width: 100%; height: 100%;
            z-index: 0;
            pointer-events: none;
        }
        
        #canvas-container canvas {
            display: block;
        }
        
        .custom-cursor {
            position: fixed;
            width: 20px; height: 20px;
            border: 2px solid var(--electric-blue);
            border-radius: 50%;
            pointer-events: none;
            z-index: 9999;
            transition: transform 0.1s ease;
            box-shadow: var(--glow-blue);
        }
        
        .cursor-trail {
            position: fixed;
            width: 8px; height: 8px;
            background: var(--electric-blue);
            border-radius: 50%;
            pointer-events: none;
            z-index: 9998;
            opacity: 0.6;
            box-shadow: var(--glow-blue);
        }
        
        .holo-nav {
            position: fixed;
            top: 30px;
            left: 50%;
            transform: translateX(-50%);
            z-index: 100;
            display: flex;
            gap: 15px;
            padding: 15px 30px;
            background: rgba(5, 5, 16, 0.4);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(0, 212, 255, 0.2);
            border-radius: 50px;
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        }
        
        .holo-nav:hover {
            background: rgba(5, 5, 16, 0.7);
            border-color: rgba(0, 212, 255, 0.5);
            box-shadow: 0 0 30px rgba(0, 212, 255, 0.2);
        }
        
        .nav-pill {
            padding: 10px 24px;
            border: 1px solid rgba(0, 212, 255, 0.3);
            border-radius: 25px;
            color: #a0a0ff;
            text-decoration: none;
            font-family: 'Orbitron', sans-serif;
            font-size: 0.85rem;
            font-weight: 500;
            letter-spacing: 2px;
            text-transform: uppercase;
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            position: relative;
            overflow: hidden;
            background: transparent;
            cursor: none;
        }
        
        .nav-pill::before {
            content: '';
            position: absolute;
            top: 0; left: -100%;
            width: 100%; height: 100%;
            background: linear-gradient(90deg, transparent, rgba(0, 212, 255, 0.2), transparent);
            transition: left 0.5s ease;
        }
        
        .nav-pill:hover::before {
            left: 100%;
        }
        
        .nav-pill:hover {
            color: var(--electric-blue);
            border-color: var(--electric-blue);
            box-shadow: var(--glow-blue);
            transform: translateY(-3px);
            text-shadow: 0 0 10px rgba(0, 212, 255, 0.5);
        }
        
        .nav-pill.active {
            color: var(--electric-blue);
            border-color: var(--electric-blue);
            box-shadow: var(--glow-blue);
        }
        
        .section {
            position: relative;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 10;
            padding: 100px 5%;
        }
        
        .hero-section {
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            text-align: center;
            position: relative;
        }
        
        .hero-title {
            font-family: 'Orbitron', sans-serif;
            font-size: clamp(3rem, 8vw, 7rem);
            font-weight: 900;
            letter-spacing: 8px;
            text-transform: uppercase;
            background: linear-gradient(135deg, var(--electric-blue), var(--deep-violet), var(--cosmic-gold));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            text-shadow: none;
            position: relative;
            z-index: 20;
            margin-bottom: 20px;
            animation: titlePulse 3s ease-in-out infinite;
        }
        
        @keyframes titlePulse {
            0%, 100% { filter: brightness(1); }
            50% { filter: brightness(1.3); }
        }
        
        .hero-subtitle {
            font-family: 'Space Mono', monospace;
            font-size: clamp(1rem, 2.5vw, 1.5rem);
            color: #a0a0ff;
            letter-spacing: 6px;
            text-transform: uppercase;
            margin-bottom: 40px;
            z-index: 20;
            position: relative;
        }
        
        .hero-tagline {
            font-family: 'Rajdhani', sans-serif;
            font-size: clamp(1rem, 2vw, 1.3rem);
            color: rgba(160, 160, 255, 0.8);
            max-width: 600px;
            line-height: 1.8;
            z-index: 20;
            position: relative;
        }
        
        .scroll-indicator {
            position: absolute;
            bottom: 40px;
            left: 50%;
            transform: translateX(-50%);
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 10px;
            z-index: 20;
            animation: bounce 2s ease-in-out infinite;
        }
        
        .scroll-indicator span {
            font-family: 'Orbitron', sans-serif;
            font-size: 0.7rem;
            letter-spacing: 4px;
            color: rgba(0, 212, 255, 0.6);
        }
        
        .scroll-line {
            width: 1px;
            height: 60px;
            background: linear-gradient(to bottom, var(--electric-blue), transparent);
        }
        
        @keyframes bounce {
            0%, 100% { transform: translateX(-50%) translateY(0); }
            50% { transform: translateX(-50%) translateY(-10px); }
        }
        
        .about-section {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 80px;
            align-items: center;
            max-width: 1400px;
            margin: 0 auto;
        }
        
        .about-content h2 {
            font-family: 'Orbitron', sans-serif;
            font-size: clamp(2rem, 4vw, 3.5rem);
            font-weight: 700;
            color: var(--electric-blue);
            margin-bottom: 30px;
            letter-spacing: 4px;
            text-shadow: 0 0 20px rgba(0, 212, 255, 0.3);
        }
        
        .about-text {
            font-size: 1.1rem;
            line-height: 2;
            color: rgba(224, 224, 255, 0.85);
            margin-bottom: 30px;
        }
        
        .typing-text {
            font-family: 'Space Mono', monospace;
            font-size: 1rem;
            color: var(--cosmic-gold);
            line-height: 1.8;
            min-height: 120px;
        }
        
        .typing-text .cursor {
            display: inline-block;
            width: 2px;
            height: 1.2em;
            background: var(--electric-blue);
            animation: blink 0.8s step-end infinite;
            vertical-align: text-bottom;
            margin-left: 2px;
        }
        
        @keyframes blink {
            0%, 100% { opacity: 1; }
            50% { opacity: 0; }
        }
        
        .data-cards {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 20px;
            margin-top: 40px;
        }
        
        .data-card {
            background: rgba(0, 212, 255, 0.05);
            border: 1px solid rgba(0, 212, 255, 0.2);
            border-radius: 16px;
            padding: 25px;
            transition: all 0.4s ease;
            position: relative;
            overflow: hidden;
        }
        
        .data-card::before {
            content: '';
            position: absolute;
            top: 0; left: 0;
            width: 100%; height: 2px;
            background: linear-gradient(90deg, var(--electric-blue), var(--deep-violet));
            transform: scaleX(0);
            transform-origin: left;
            transition: transform 0.4s ease;
        }
        
        .data-card:hover::before {
            transform: scaleX(1);
        }
        
        .data-card:hover {
            transform: translateY(-5px);
            border-color: rgba(0, 212, 255, 0.4);
            box-shadow: 0 10px 40px rgba(0, 212, 255, 0.1);
        }
        
        .data-card .number {
            font-family: 'Orbitron', sans-serif;
            font-size: 2.5rem;
            font-weight: 700;
            color: var(--electric-blue);
            margin-bottom: 8px;
        }
        
        .data-card .label {
            font-size: 0.9rem;
            color: rgba(160, 160, 255, 0.7);
            text-transform: uppercase;
            letter-spacing: 2px;
        }
        
        .astronaut-container {
            position: relative;
            width: 100%;
            height: 500px;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        
        .skills-section {
            text-align: center;
            max-width: 1400px;
            margin: 0 auto;
        }
        
        .skills-section h2 {
            font-family: 'Orbitron', sans-serif;
            font-size: clamp(2rem, 4vw, 3.5rem);
            font-weight: 700;
            color: var(--electric-blue);
            margin-bottom: 20px;
            letter-spacing: 4px;
            text-shadow: 0 0 20px rgba(0, 212, 255, 0.3);
        }
        
        .skills-subtitle {
            font-size: 1.1rem;
            color: rgba(160, 160, 255, 0.7);
            margin-bottom: 60px;
        }
        
        .skills-orbit {
            position: relative;
            width: 100%;
            height: 600px;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        
        .skill-planet {
            position: absolute;
            width: 120px;
            height: 120px;
            border-radius: 50%;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            cursor: none;
            transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
            border: 2px solid;
            background: rgba(5, 5, 16, 0.8);
            backdrop-filter: blur(10px);
        }
        
        .skill-planet:hover {
            transform: scale(1.3);
            z-index: 50;
        }
        
        .skill-planet .skill-icon {
            font-size: 2rem;
            margin-bottom: 5px;
        }
        
        .skill-planet .skill-name {
            font-family: 'Orbitron', sans-serif;
            font-size: 0.75rem;
            font-weight: 600;
            letter-spacing: 1px;
        }
        
        .skill-planet .skill-level {
            position: absolute;
            bottom: -30px;
            font-size: 0.8rem;
            color: var(--cosmic-gold);
            opacity: 0;
            transition: opacity 0.3s ease;
        }
        
        .skill-planet:hover .skill-level {
            opacity: 1;
        }
        
        .skill-planet.python {
            border-color: #3776ab;
            box-shadow: 0 0 30px rgba(55, 118, 171, 0.4), inset 0 0 30px rgba(55, 118, 171, 0.1);
            color: #3776ab;
        }
        
        .skill-planet.htmlcss {
            border-color: #e34c26;
            box-shadow: 0 0 30px rgba(227, 76, 38, 0.4), inset 0 0 30px rgba(227, 76, 38, 0.1);
            color: #e34c26;
        }
        
        .skill-planet.design {
            border-color: #ff6b9d;
            box-shadow: 0 0 30px rgba(255, 107, 157, 0.4), inset 0 0 30px rgba(255, 107, 157, 0.1);
            color: #ff6b9d;
        }
        
        .skill-planet.office {
            border-color: #00a4ef;
            box-shadow: 0 0 30px rgba(0, 164, 239, 0.4), inset 0 0 30px rgba(0, 164, 239, 0.1);
            color: #00a4ef;
        }
        
        .skill-planet.ai {
            border-color: var(--deep-violet);
            box-shadow: 0 0 30px rgba(124, 58, 237, 0.4), inset 0 0 30px rgba(124, 58, 237, 0.1);
            color: var(--deep-violet);
        }
        
        .skill-planet.ml {
            border-color: var(--cosmic-gold);
            box-shadow: 0 0 30px rgba(255, 215, 0, 0.4), inset 0 0 30px rgba(255, 215, 0, 0.1);
            color: var(--cosmic-gold);
        }
        
        .ai-brain {
            width: 150px;
            height: 150px;
            border: 2px solid var(--electric-blue);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            animation: brainPulse 2s ease-in-out infinite;
            background: rgba(0, 212, 255, 0.05);
        }
        
        @keyframes brainPulse {
            0%, 100% { box-shadow: 0 0 20px rgba(0, 212, 255, 0.3); }
            50% { box-shadow: 0 0 40px rgba(0, 212, 255, 0.6); }
        }
        
        .ai-brain svg {
            width: 80px;
            height: 80px;
        }
        
        .resume-section {
            max-width: 1200px;
            margin: 0 auto;
            text-align: center;
        }
        
        .resume-section h2 {
            font-family: 'Orbitron', sans-serif;
            font-size: clamp(2rem, 4vw, 3.5rem);
            font-weight: 700;
            color: var(--electric-blue);
            margin-bottom: 60px;
            letter-spacing: 4px;
            text-shadow: 0 0 20px rgba(0, 212, 255, 0.3);
        }
        
        .timeline {
            position: relative;
            padding: 40px 0;
        }
        
        .timeline::before {
            content: '';
            position: absolute;
            left: 50%;
            top: 0;
            bottom: 0;
            width: 2px;
            background: linear-gradient(to bottom, var(--electric-blue), var(--deep-violet), var(--cosmic-gold));
            transform: translateX(-50%);
        }
        
        .timeline-item {
            position: relative;
            margin-bottom: 60px;
            display: flex;
            align-items: center;
        }
        
        .timeline-item:nth-child(odd) {
            flex-direction: row-reverse;
            text-align: right;
        }
        
        .timeline-item:nth-child(even) {
            text-align: left;
        }
        
        .timeline-content {
            width: 45%;
            padding: 30px;
            background: rgba(0, 212, 255, 0.05);
            border: 1px solid rgba(0, 212, 255, 0.2);
            border-radius: 20px;
            transition: all 0.4s ease;
            position: relative;
        }
        
        .timeline-content::after {
            content: '';
            position: absolute;
            top: 50%;
            width: 20px;
            height: 20px;
            background: var(--electric-blue);
            border-radius: 50%;
            box-shadow: 0 0 20px rgba(0, 212, 255, 0.6);
        }
        
        .timeline-item:nth-child(odd) .timeline-content::after {
            left: -60px;
            transform: translateY(-50%);
        }
        
        .timeline-item:nth-child(even) .timeline-content::after {
            right: -60px;
            transform: translateY(-50%);
        }
        
        .timeline-content:hover {
            transform: translateY(-5px);
            border-color: rgba(0, 212, 255, 0.5);
            box-shadow: 0 15px 50px rgba(0, 212, 255, 0.15);
        }
        
        .timeline-content h3 {
            font-family: 'Orbitron', sans-serif;
            font-size: 1.3rem;
            color: var(--electric-blue);
            margin-bottom: 10px;
        }
        
        .timeline-content .date {
            font-family: 'Space Mono', monospace;
            font-size: 0.85rem;
            color: var(--cosmic-gold);
            margin-bottom: 15px;
            display: block;
        }
        
        .timeline-content p {
            font-size: 1rem;
            color: rgba(224, 224, 255, 0.8);
            line-height: 1.7;
        }
        
        .download-meteor {
            display: inline-flex;
            align-items: center;
            gap: 12px;
            padding: 18px 40px;
            background: linear-gradient(135deg, var(--electric-blue), var(--deep-violet));
            border: none;
            border-radius: 50px;
            color: #fff;
            font-family: 'Orbitron', sans-serif;
            font-size: 1rem;
            font-weight: 600;
            letter-spacing: 3px;
            text-transform: uppercase;
            cursor: none;
            margin-top: 40px;
            position: relative;
            overflow: hidden;
            transition: all 0.4s ease;
            text-decoration: none;
        }
        
        .download-meteor:hover {
            transform: scale(1.05);
            box-shadow: 0 0 40px rgba(0, 212, 255, 0.5);
        }
        
        .download-meteor .meteor-icon {
            font-size: 1.5rem;
            animation: meteorShake 0.5s ease-in-out infinite;
        }
        
        @keyframes meteorShake {
            0%, 100% { transform: rotate(-5deg); }
            50% { transform: rotate(5deg); }
        }
        
        .contact-section {
            max-width: 800px;
            margin: 0 auto;
            text-align: center;
        }
        
        .contact-section h2 {
            font-family: 'Orbitron', sans-serif;
            font-size: clamp(2rem, 4vw, 3.5rem);
            font-weight: 700;
            color: var(--electric-blue);
            margin-bottom: 20px;
            letter-spacing: 4px;
            text-shadow: 0 0 20px rgba(0, 212, 255, 0.3);
        }
        
        .contact-subtitle {
            font-size: 1.1rem;
            color: rgba(160, 160, 255, 0.7);
            margin-bottom: 50px;
        }
        
        .holo-form {
            background: rgba(0, 212, 255, 0.03);
            border: 1px solid rgba(0, 212, 255, 0.2);
            border-radius: 24px;
            padding: 50px;
            position: relative;
            overflow: hidden;
        }
        
        .holo-form::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0;
            height: 2px;
            background: linear-gradient(90deg, transparent, var(--electric-blue), var(--deep-violet), var(--cosmic-gold), transparent);
        }
        
        .form-group {
            margin-bottom: 30px;
            text-align: left;
        }
        
        .form-group label {
            display: block;
            font-family: 'Orbitron', sans-serif;
            font-size: 0.8rem;
            letter-spacing: 3px;
            color: var(--electric-blue);
            margin-bottom: 12px;
            text-transform: uppercase;
        }
        
        .form-group input,
        .form-group textarea {
            width: 100%;
            padding: 16px 20px;
            background: rgba(0, 212, 255, 0.05);
            border: 1px solid rgba(0, 212, 255, 0.2);
            border-radius: 12px;
            color: #e0e0ff;
            font-family: 'Rajdhani', sans-serif;
            font-size: 1rem;
            transition: all 0.3s ease;
            outline: none;
        }
        
        .form-group input:focus,
        .form-group textarea:focus {
            border-color: var(--electric-blue);
            box-shadow: 0 0 20px rgba(0, 212, 255, 0.2);
            background: rgba(0, 212, 255, 0.08);
        }
        
        .form-group input::placeholder,
        .form-group textarea::placeholder {
            color: rgba(160, 160, 255, 0.4);
        }
        
        .form-group textarea {
            min-height: 150px;
            resize: vertical;
        }
        
        .submit-rocket {
            display: inline-flex;
            align-items: center;
            gap: 12px;
            padding: 18px 50px;
            background: linear-gradient(135deg, var(--electric-blue), var(--deep-violet));
            border: none;
            border-radius: 50px;
            color: #fff;
            font-family: 'Orbitron', sans-serif;
            font-size: 1rem;
            font-weight: 600;
            letter-spacing: 3px;
            text-transform: uppercase;
            cursor: none;
            position: relative;
            overflow: hidden;
            transition: all 0.4s ease;
        }
        
        .submit-rocket:hover {
            transform: scale(1.05);
            box-shadow: 0 0 40px rgba(0, 212, 255, 0.5);
        }
        
        .submit-rocket .rocket-icon {
            font-size: 1.3rem;
            transition: transform 0.3s ease;
        }
        
        .submit-rocket:hover .rocket-icon {
            transform: translateY(-3px);
        }
        
        .footer {
            text-align: center;
            padding: 60px 20px;
            border-top: 1px solid rgba(0, 212, 255, 0.1);
        }
        
        .footer p {
            font-family: 'Space Mono', monospace;
            font-size: 0.85rem;
            color: rgba(160, 160, 255, 0.5);
            letter-spacing: 2px;
        }
        
        .footer .name {
            color: var(--electric-blue);
            font-weight: 700;
        }
        
        .warp-overlay {
            position: fixed;
            top: 0; left: 0;
            width: 100%; height: 100%;
            pointer-events: none;
            z-index: 5;
            opacity: 0;
            transition: opacity 0.3s ease;
        }
        
        .warp-overlay.active {
            opacity: 1;
        }
        
        @media (max-width: 968px) {
            .about-section {
                grid-template-columns: 1fr;
                gap: 40px;
            }
            
            .timeline-item,
            .timeline-item:nth-child(odd) {
                flex-direction: column;
                text-align: center;
            }
            
            .timeline-content {
                width: 90%;
            }
            
            .timeline::before {
                left: 20px;
            }
            
            .timeline-content::after {
                left: -35px !important;
                right: auto !important;
            }
            
            .holo-nav {
                flex-wrap: wrap;
                justify-content: center;
                padding: 10px 20px;
                gap: 8px;
            }
            
            .nav-pill {
                padding: 8px 16px;
                font-size: 0.75rem;
            }
            
            .skills-orbit {
                height: 400px;
            }
            
            .skill-planet {
                width: 90px;
                height: 90px;
            }
            
            .skill-planet .skill-icon {
                font-size: 1.5rem;
            }
            
            .skill-planet .skill-name {
                font-size: 0.6rem;
            }
        }
        
        @media (max-width: 600px) {
            .holo-form {
                padding: 30px 20px;
            }
            
            .data-cards {
                grid-template-columns: 1fr;
            }
            
            .section {
                padding: 80px 20px;
            }
