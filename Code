        function createShootingStar() {
            const geometry = new THREE.BufferGeometry();
            const positions = new Float32Array(20 * 3);
            const colors = new Float32Array(20 * 3);
            
            const startX = (Math.random() - 0.5) * 100;
            const startY = 30 + Math.random() * 20;
            const startZ = -30 - Math.random() * 50;
            const endX = startX + (Math.random() - 0.5) * 40;
            const endY = startY - 20 - Math.random() * 20;
            const endZ = startZ - 20 - Math.random() * 30;
            
            for (let i = 0; i < 20; i++) {
                const t = i / 19;
                positions[i * 3] = startX + (endX - startX) * t;
                positions[i * 3 + 1] = startY + (endY - startY) * t;
                positions[i * 3 + 2] = startZ + (endZ - startZ) * t;
                
                const brightness = 1 - t * 0.5;
                colors[i * 3] = 1.0;
                colors[i * 3 + 1] = 0.9;
                colors[i * 3 + 2] = 0.6;
            }
            
            geometry.setAttribute('position', new THREE.BufferAttribute(positions, 3));
            geometry.setAttribute('color', new THREE.BufferAttribute(colors, 3));
            
            const material = new THREE.PointsMaterial({
                size: 0.8,
                vertexColors: true,
                transparent: true,
                opacity: 1,
                blending: THREE.AdditiveBlending
            });
            
            const shootingStar = new THREE.Points(geometry, material);
            shootingStar.userData = {
                life: 1.0,
                speed: 0.02 + Math.random() * 0.03
            };
            
            scene.add(shootingStar);
            shootingStars.push(shootingStar);
        }
        
        let lastShootingStarTime = 0;
        
        function animate() {
            requestAnimationFrame(animate);
            
            time += 0.016;
            
            mouseX += (targetMouseX - mouseX) * 0.05;
            mouseY += (targetMouseY - mouseY) * 0.05;
            
            camera.position.x = mouseX * 3;
            camera.position.y = mouseY * 2;
            camera.lookAt(0, 0, 0);
            
            const scrollFactor = Math.min(scrollY / window.innerHeight, 2);
            camera.position.z = 30 + scrollFactor * 10;
            
            if (blackHole) {
                blackHole.rotation.x = blackHoleRotation.x;
                blackHole.rotation.y = blackHoleRotation.y + time * 0.1;
                
                if (accretionDisk) {
                    accretionDisk.material.uniforms.time.value = time;
                    accretionDisk.rotation.z = time * 0.3;
                }
                
                if (blackHole.userData.particleRing) {
                    blackHole.userData.particleRing.rotation.y = time * 0.5;
                }
                
                if (blackHole.userData.nameSprite) {
                    const orbitRadius = 20;
                    blackHole.userData.nameSprite.position.x = Math.cos(time * 0.3) * orbitRadius;
                    blackHole.userData.nameSprite.position.z = Math.sin(time * 0.3) * orbitRadius + 18;
                    blackHole.userData.nameSprite.position.y = Math.sin(time * 0.2) * 3;
                    blackHole.userData.nameSprite.lookAt(camera.position);
                }
            }
            
            if (stars) {
                stars.rotation.y = mouseX * 0.02;
                stars.rotation.x = mouseY * 0.02;
                const scrollSpeed = Math.abs(window.scrollY - (window.lastScrollY || 0));
                window.lastScrollY = window.scrollY;
                stars.rotation.y += scrollSpeed * 0.001;
            }
            
            if (nebula) {
                nebula.material.uniforms.time.value = time;
                nebula.rotation.z = 0.3 + Math.sin(time * 0.1) * 0.05;
            }
            
            if (planet) {
                planet.rotation.y = time * 0.05;
                if (planet.userData.ring) {
                    planet.userData.ring.material.uniforms.time.value = time;
                }
            }
            
            asteroids.forEach(asteroid => {
                asteroid.rotation.x += asteroid.userData.rotSpeed.x;
                asteroid.rotation.y += asteroid.userData.rotSpeed.y;
                asteroid.rotation.z += asteroid.userData.rotSpeed.z;
                asteroid.position.y += Math.sin(time + asteroid.id) * 0.01;
            });
            
            if (time - lastShootingStarTime > 3 + Math.random() * 4) {
                createShootingStar();
                lastShootingStarTime = time;
            }
            
            for (let i = shootingStars.length - 1; i >= 0; i--) {
                const ss = shootingStars[i];
                ss.userData.life -= ss.userData.speed;
                ss.material.opacity = ss.userData.life;
                
                const positions = ss.geometry.attributes.position.array;
                for (let j = 0; j < positions.length; j += 3) {
                    positions[j + 2] -= 0.5;
                }
                ss.geometry.attributes.position.needsUpdate = true;
                
                if (ss.userData.life <= 0) {
                    scene.remove(ss);
                    shootingStars.splice(i, 1);
                }
            }
            
            renderer.render(scene, camera);
        }
        
