            const pointLight = new THREE.PointLight(0x00d4ff, 2, 100);
            pointLight.position.set(0, 0, 0);
            scene.add(pointLight);
            
            const violetLight = new THREE.PointLight(0x7c3aed, 1, 80);
            violetLight.position.set(-20, 10, -10);
            scene.add(violetLight);
            
            const goldLight = new THREE.PointLight(0xffd700, 0.8, 60);
