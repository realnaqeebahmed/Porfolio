                        float alpha = smoothstep(10.0, 11.0, vRadius) * smoothstep(16.0, 15.0, vRadius) * 0.6;
                        gl_FragColor = vec4(color, alpha);
                    }
                `,
                transparent: true,
                side: THREE.DoubleSide,
