        function initWarpSpeed() {
            const canvas = document.getElementById('warpCanvas');
            const ctx = canvas.getContext('2d');
            canvas.width = window.innerWidth;
            canvas.height = window.innerHeight;
            
            let warpStars = [];
            let warpActive = false;
            let warpSpeed = 0;
            
            for (let i = 0; i < 200; i++) {
                warpStars.push({
                    x: Math.random() * canvas.width,
                    y: Math.random() * canvas.height,
                    z: Math.random() * 1000
                });
            }
            
            function drawWarp() {
                if (!warpActive && warpSpeed <= 0) {
                    requestAnimationFrame(drawWarp);
                    return;
                }
                
                ctx.fillStyle = 'rgba(5, 5, 16, 0.2)';
                ctx.fillRect(0, 0, canvas.width, canvas.height);
                
                const centerX = canvas.width / 2;
                const centerY = canvas.height / 2;
                
                warpStars.forEach(star => {
                    star.z -= warpSpeed * 2;
                    if (star.z <= 0) {
                        star.z = 1000;
                        star.x = Math.random() * canvas.width;
                        star.y = Math.random() * canvas.height;
                    }
                    
                    const x = (star.x - centerX) * (1000 / star.z) + centerX;
                    const y = (star.y - centerY) * (1000 / star.z) + centerY;
                    const size = (1 - star.z / 1000) * 3;
                    const alpha = (1 - star.z / 1000);
                    
                    ctx.beginPath();
                    ctx.moveTo(x, y);
                    ctx.lineTo(
                        (star.x - centerX) * (1000 / (star.z + warpSpeed * 10)) + centerX,
                        (star.y - centerY) * (1000 / (star.z + warpSpeed * 10)) + centerY
                    );
                    ctx.strokeStyle = `rgba(0, 212, 255, ${alpha})`;
                    ctx.lineWidth = size;
                    ctx.stroke();
                });
                
                if (warpActive) {
                    warpSpeed = Math.min(warpSpeed + 1, 20);
                } else {
                    warpSpeed = Math.max(warpSpeed - 0.5, 0);
                }
                
                requestAnimationFrame(drawWarp);
            }
            
            drawWarp();
            
            window.activateWarpSpeed = function() {
                warpActive = true;
                canvas.classList.add('active');
            };
            
            window.deactivateWarpSpeed = function() {
                warpActive = false;
                setTimeout(() => {
                    canvas.classList.remove('active');
                }, 1000);
            };
        }
        
