                    const currentTop = parseFloat(draggedPlanet.style.top || 0);
                    
                    gsap.to(draggedPlanet, {
                        left: currentLeft + planetVelocity.x * throwDistance,
                        top: currentTop + planetVelocity.y * throwDistance,
                        duration: 0.8,
                        ease: 'power2.out'
                    });
                    
                    draggedPlanet = null;
                }
            });
            
            function animateOrbit() {
                if (!isDraggingPlanet) {
                    planets.forEach((planet, i) => {
                        const t = (Date.now() / 1000 / (20 + i * 3) + i / planets.length) % 1;
                        const angle = t * Math.PI * 2;
                        const x = centerX + Math.cos(angle) * radius - 60;
                        const y = centerY + Math.sin(angle) * radius * 0.4 - 60;
                        
                        if (planet !== draggedPlanet) {
                            planet.style.left = x + 'px';
                            planet.style.top = y + 'px';
                        }
                    });
                }
                requestAnimationFrame(animateOrbit);
            }
            animateOrbit();
        }
        
        function createAstronautModel() {
            const container = document.getElementById('astronautContainer');
            
            const astroScene = new THREE.Scene();
            const astroCamera = new THREE.PerspectiveCamera(50, 1, 0.1, 100);
            astroCamera.position.z = 5;
            
            const astroRenderer = new THREE.WebGLRenderer({ alpha: true, antialias: true });
            astroRenderer.setSize(400, 400);
            astroRenderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
            container.appendChild(astroRenderer.domElement);
            
            const astronaut = new THREE.Group();
            
            const helmetGeometry = new THREE.SphereGeometry(1.2, 32, 32);
            const helmetMaterial = new THREE.MeshStandardMaterial({
                color: 0xeeeeee,
                roughness: 0.3,
                metalness: 0.5
            });
            const helmet = new THREE.Mesh(helmetGeometry, helmetMaterial);
            astronaut.add(helmet);
            
            const visorGeometry = new THREE.SphereGeometry(1.0, 32, 32, 0, Math.PI * 2, 0, Math.PI * 0.35);
            const visorMaterial = new THREE.MeshStandardMaterial({
                color: 0x111122,
                roughness: 0.1,
                metalness: 0.9,
                emissive: 0x001133,
                emissiveIntensity: 0.3
            });
            const visor = new THREE.Mesh(visorGeometry, visorMaterial);
            visor.rotation.x = -Math.PI / 2;
            visor.position.z = 0.3;
            astronaut.add(visor);
            
            const bodyGeometry = new THREE.CylinderGeometry(0.8, 1.0, 1.5, 32);
            const bodyMaterial = new THREE.MeshStandardMaterial({
                color: 0xdddddd,
                roughness: 0.4,
                metalness: 0.4
            });
            const body = new THREE.Mesh(bodyGeometry, bodyMaterial);
            body.position.y = -1.5;
            astronaut.add(body);
            
            const backpackGeometry = new THREE.BoxGeometry(1.5, 1.2, 0.6);
            const backpackMaterial = new THREE.MeshStandardMaterial({
                color: 0xcccccc,
                roughness: 0.5,
                metalness: 0.3
            });
            const backpack = new THREE.Mesh(backpackGeometry, backpackMaterial);
            backpack.position.set(0, -1.3, -0.8);
            astronaut.add(backpack);
            
            const ambientLight = new THREE.AmbientLight(0x404040, 0.5);
            astroScene.add(ambientLight);
            
            const dirLight = new THREE.DirectionalLight(0x00d4ff, 1);
            dirLight.position.set(5, 5, 5);
            astroScene.add(dirLight);
            
            const backLight = new THREE.DirectionalLight(0x7c3aed, 0.5);
            backLight.position.set(-5, -5, -5);
            astroScene.add(backLight);
            
            astroScene.add(astronaut);
            
            let astroMouseX = 0, astroMouseY = 0;
            let astroTargetX = 0, astroTargetY = 0;
            let isDraggingAstro = false;
            
            container.addEventListener('mousemove', (e) => {
                const rect = container.getBoundingClientRect();
                astroTargetX = ((e.clientX - rect.left) / rect.width) * 2 - 1;
                astroTargetY = -((e.clientY - rect.top) / rect.height) * 2 + 1;
            });
            
            container.addEventListener('mousedown', () => {
                isDraggingAstro = true;
            });
            
            container.addEventListener('mouseup', () => {
                isDraggingAstro = false;
            });
            
            function animateAstronaut() {
                requestAnimationFrame(animateAstronaut);
                
                astroMouseX += (astroTargetX - astroMouseX) * 0.05;
                astroMouseY += (astroTargetY - astroMouseY) * 0.05;
                
                astronaut.rotation.y = astroMouseX * 0.5;
                astronaut.rotation.x = astroMouseY * 0.3;
                
                astronaut.position.y = Math.sin(Date.now() * 0.001) * 0.1;
                
                if (isDraggingAstro) {
                    astronaut.rotation.y += 0.02;
                }
                
                astroRenderer.render(astroScene, astroCamera);
            }
            animateAstronaut();
        }
        
        document.addEventListener('DOMContentLoaded', () => {
            initThreeJS();
            
            setTimeout(() => {
                initGSAP();
            }, 500);
            
            initTypingEffect();
            initNavigation();
            initWarpSpeed();
            initSkillPlanets();
            
            setTimeout(() => {
                createAstronautModel();
            }, 1000);
            
            document.querySelectorAll('.nav-pill').forEach(pill => {
                pill.addEventListener('mouseenter', () => {
                    gsap.to(pill, {
                        boxShadow: '0 0 30px rgba(0, 212, 255, 0.6), 0 0 60px rgba(0, 212, 255, 0.3)',
                        duration: 0.3
                    });
                });
                
                pill.addEventListener('mouseleave', () => {
                    gsap.to(pill, {
                        boxShadow: 'none',
                        duration: 0.3
                    });
                });
            });
            
            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        const numberEl = entry.target.querySelector('.number');
                        const target = numberEl.textContent;
                        const isInfinite = target === '∞';
                        
                        if (!isInfinite && !isNaN(parseInt(target))) {
                            const targetNum = parseInt(target);
                            let current = 0;
                            const increment = targetNum / 50;
                            
                            const counter = setInterval(() => {
                                current += increment;
                                if (current >= targetNum) {
                                    numberEl.textContent = target;
                                    clearInterval(counter);
                                } else {
                                    numberEl.textContent = Math.floor(current) + '+';
                                }
                            }, 30);
                        }
                        
                        observer.unobserve(entry.target);
                    }
                });
            }, { threshold: 0.5 });
            
            document.querySelectorAll('.data-card').forEach(card => {
                observer.observe(card);
            });
            
            document.querySelectorAll('.form-group input, .form-group textarea').forEach(input => {
                input.addEventListener('focus', () => {
                    gsap.to(input, {
                        borderColor: '#00d4ff',
                        boxShadow: '0 0 20px rgba(0, 212, 255, 0.2)',
                        duration: 0.3
                    });
                });
                
                input.addEventListener('blur', () => {
                    gsap.to(input, {
                        borderColor: 'rgba(0, 212, 255, 0.2)',
                        boxShadow: 'none',
                        duration: 0.3
                    });
                });
            });
            
            gsap.to('.scroll-line', {
                scaleY: 1.2,
                opacity: 0.5,
                duration: 1,
                repeat: -1,
                yoyo: true,
                ease: 'power2.inOut'
            });
        });
        
        document.addEventListener('visibilitychange', () => {
            if (document.hidden) {
                // Reduce quality when hidden
            }
        });
    </script>
</body>
</html>
