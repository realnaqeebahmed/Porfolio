    <script>
        let scene, camera, renderer;
        let blackHole, accretionDisk, stars, nebula, planet, asteroids = [];
        let mouseX = 0, mouseY = 0;
        let targetMouseX = 0, targetMouseY = 0;
        let scrollY = 0;
        let isDragging = false;
        let previousMousePosition = { x: 0, y: 0 };
        let blackHoleRotation = { x: 0, y: 0 };
        let shootingStars = [];
        let time = 0;
        
        let loadingProgress = 0;
        const loadingBarFill = document.getElementById('loadingBarFill');
        const loadingPercentage = document.getElementById('loadingPercentage');
        const loadingScreen = document.getElementById('loadingScreen');
        
        function updateLoading(progress) {
            loadingProgress = Math.min(progress, 100);
            loadingBarFill.style.width = loadingProgress + '%';
            loadingPercentage.textContent = Math.round(loadingProgress) + '%';
            if (loadingProgress >= 100) {
                setTimeout(() => {
                    loadingScreen.classList.add('hidden');
                }, 500);
            }
        }
        
        updateLoading(10);
        
        // Custom Cursor
        const customCursor = document.getElementById('customCursor');
        const cursorTrails = [];
        const TRAIL_COUNT = 8;
        
        for (let i = 0; i < TRAIL_COUNT; i++) {
            const trail = document.createElement('div');
            trail.className = 'cursor-trail';
            trail.style.opacity = (1 - i / TRAIL_COUNT) * 0.6;
            trail.style.width = (8 - i * 0.5) + 'px';
            trail.style.height = (8 - i * 0.5) + 'px';
            document.body.appendChild(trail);
            cursorTrails.push({ el: trail, x: 0, y: 0 });
        }
        
        document.addEventListener('mousemove', (e) => {
            targetMouseX = (e.clientX / window.innerWidth) * 2 - 1;
            targetMouseY = -(e.clientY / window.innerHeight) * 2 + 1;
            
            customCursor.style.left = e.clientX - 10 + 'px';
            customCursor.style.top = e.clientY - 10 + 'px';
            
            if (isDragging && blackHole) {
                const deltaX = e.clientX - previousMousePosition.x;
                const deltaY = e.clientY - previousMousePosition.y;
                blackHoleRotation.y += deltaX * 0.005;
                blackHoleRotation.x += deltaY * 0.005;
            }
            previousMousePosition = { x: e.clientX, y: e.clientY };
        });
        
        document.addEventListener('mousedown', () => {
            isDragging = true;
            customCursor.style.transform = 'scale(0.8)';
        });
        
        document.addEventListener('mouseup', () => {
            isDragging = false;
            customCursor.style.transform = 'scale(1)';
        });
        
        let cursorX = 0, cursorY = 0;
        document.addEventListener('mousemove', (e) => {
            cursorX = e.clientX;
            cursorY = e.clientY;
        });
        
        function animateCursorTrail() {
            cursorTrails.forEach((trail, i) => {
                const delay = (i + 1) * 0.08;
                trail.x += (cursorX - trail.x) * delay;
                trail.y += (cursorY - trail.y) * delay;
                trail.el.style.left = trail.x - 4 + 'px';
                trail.el.style.top = trail.y - 4 + 'px';
            });
            requestAnimationFrame(animateCursorTrail);
        }
        animateCursorTrail();
        
        window.addEventListener('scroll', () => {
            scrollY = window.scrollY;
        });
        
        updateLoading(25);
        
        function initThreeJS() {
            const container = document.getElementById('canvas-container');
            
